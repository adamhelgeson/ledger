# ── Ledger Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in values. Never commit .env to source control.

# Path where the SQLite database and uploads are stored.
# Relative to the Ledger.Api project directory.
DATA_DIR=./data

# CORS — frontend origin(s) allowed to call the API (comma-separated in prod)
ALLOWED_ORIGINS=http://localhost:3000

# API ports (non-default to avoid conflicts)
# HTTP:  5050
# HTTPS: 5051

# Frontend dev server port
# VITE_PORT=3000

# Claude API key (for Heimdall chat agent — Session 2+)
# CLAUDE_API_KEY=sk-ant-...

# VITE public env vars (prefix with VITE_ to expose to frontend)
# VITE_API_BASE_URL=http://localhost:5050
